{
  "output": "pretty.phar",
  "compression": "GZ",
  "check-requirements": false,
  "compactors": [
    "KevinGH\\Box\\Compactor\\PhpScoper"
  ],
  "shebang": false,
  "finder": [
    {
      "name": "*.php",
      "in": "."
    },
    {
      "name": "*.php",
      "in": "vendor"
    },
    {
      "in": "vendor/stechstudio/phpinfo/dist"
    },
    {
      "in": "vendor/stechstudio/phpinfo/resources"
    }
  ]
}
